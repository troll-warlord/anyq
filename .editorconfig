# EditorConfig — https://editorconfig.org
# Editors that support this (VS Code with the EditorConfig extension,
# GoLand, Vim, etc.) will automatically apply these settings per file type.
# Install the VS Code extension: "EditorConfig for VS Code" (editorconfig.editorconfig)

root = true

# ── Defaults for all files ────────────────────────────────────────────────────
[*]
charset               = utf-8
end_of_line           = lf
insert_final_newline  = true
trim_trailing_whitespace = true

# ── Go source files ───────────────────────────────────────────────────────────
# gofmt ALWAYS uses tabs. Do not change indent_style to space here —
# it will create a permanent conflict with gofmt and break the linter.
[*.go]
indent_style = tab
indent_size  = 4

# ── Go module files ───────────────────────────────────────────────────────────
[go.{mod,sum}]
indent_style = tab
indent_size  = 4

# ── YAML / GitHub Actions / GoReleaser ───────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ── TOML ─────────────────────────────────────────────────────────────────────
[*.toml]
indent_style = space
indent_size  = 2

# ── JSON ─────────────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false   # trailing spaces are intentional in Markdown (line break)
indent_style = space
indent_size  = 2

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_style = space
indent_size  = 2

# ── Windows batch / PowerShell ────────────────────────────────────────────────
[*.{bat,cmd,ps1}]
end_of_line  = crlf
indent_style = space
indent_size  = 2

# ── Dockerfile ────────────────────────────────────────────────────────────────
[Dockerfile]
indent_style = space
indent_size  = 2
